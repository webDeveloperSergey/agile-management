model User {
  user_id       String  @id @default(uuid()) @db.Uuid
  email         String  @unique
  password      String
  role UserRole @default(USER)
  refresh_token String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedBoards Board[] // доски где я владелец
  memberships BoardMembership[] // доски где я участник

  @@map("users")
}


enum UserRole {
  ADMIN
  USER
}