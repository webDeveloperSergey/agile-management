model User {
  user_id       String  @id @default(uuid()) @db.Uuid
  email         String  @unique
  password      String
  refresh_token String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedBoards Board[] // доски где я владелец
  memberships BoardMembership[] // доски где я участник

  @@map("users")
}
